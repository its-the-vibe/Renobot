# Environment variables for Renobot
# Copy this file to .env and fill in your values.
# This file is gitignored – never commit the real .env.

# Redis password (leave blank if Redis has no authentication).
REDIS_PASSWORD=

# Slack bot token used to look up message metadata via the Slack API.
# Required for emoji reaction handling.
# The bot must have the channels:history scope.
SLACK_BOT_TOKEN=xoxb-your-token-here
